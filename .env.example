# Conexão com o PostgreSQL dwfaj (Grupo FAJ).
# Necessária para gravar os tickets e ler os catálogos (cargos / unidades).
# Copie para `.env.local` e preencha com credenciais que tenham permissão de escrita
# no schema `dho`.
DATABASE_URL="postgresql://usuario:senha@host:5432/dwfaj"

# (Opcional) Em ambientes com SSL gerenciado, descomente para aceitar o certificado do servidor.
# PGSSLMODE=require

# --- Notificações por e-mail (DP e RH) ---
# Envio via SMTP (ex.: Office 365). Sem estas variáveis, o ticket é gravado normalmente,
# mas o e-mail não é enviado (emailEnviado=false).
SMTP_HOST="smtp.office365.com"
SMTP_PORT="587"
# SMTP_SECURE="false"           # true apenas para porta 465
SMTP_USER="conta-de-servico@grupofaj.com.br"
SMTP_PASS="senha-ou-app-password"
# MAIL_FROM="dho@grupofaj.com.br"   # padrão: SMTP_USER
# Destinatários (separados por vírgula). Padrão já aponta para DP e RH:
MAIL_TO="dp@grupofaj.com.br, rh@grupofaj.com.br"

# --- Autenticação (NextAuth v5) ---
# Sem AUTH_SECRET, a plataforma roda ABERTA (modo dev sem login). Com ele, o RBAC é aplicado:
# ADMIN (Controladoria/P&D) -> /admin; GESTOR -> abre tickets; MEMBRO -> demais.
# Gere com: npx auth secret   (ou openssl rand -base64 32)
# AUTH_SECRET="troque-por-uma-chave-aleatoria"

# Login de desenvolvimento (sem Azure): permite escolher o papel no formulário de login.
# AUTH_DEV_LOGIN="true"
# AUTH_DEV_PASSWORD="dev"          # senha compartilhada do login dev (opcional)

# SSO corporativo (produção) — Microsoft Entra ID (Azure AD). App registration do Grupo FAJ.
# AUTH_MICROSOFT_ENTRA_ID_ID="client-id"
# AUTH_MICROSOFT_ENTRA_ID_SECRET="client-secret"
# AUTH_MICROSOFT_ENTRA_ID_ISSUER="https://login.microsoftonline.com/<tenant-id>/v2.0"
